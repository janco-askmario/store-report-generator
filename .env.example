# Supabase — Project Settings -> API in the Supabase dashboard.
#
# The publishable key is safe to expose in the browser; row-level security is
# what protects the data. Never put an sb_secret_... (or service_role) key in a
# NEXT_PUBLIC_ variable — Next.js inlines those into the client bundle, and
# secret keys bypass RLS entirely.
#
# The ANON_KEY name is kept for compatibility with Vercel's Supabase
# integration, which injects it under that name. Newer Supabase projects call
# the value a "publishable key" — same slot.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your-key-here
